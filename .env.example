# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here

# PostgreSQL
POSTGRES_DB=db_name
POSTGRES_USER=db_user
POSTGRES_PASSWORD=your_strong_password_here

# Bot → PostgreSQL (used inside docker-compose network)
DATABASE_URL=postgresql+asyncpg://db_user:your_strong_password_here@db:5432/db_name

# Bot → RAG server (used inside docker-compose network)
RAG_API_URL=http://server:8000/ask

# Ollama (running on host machine)
OLLAMA_HOST=http://host.docker.internal:11434

# API key for /ask endpoint (optional; leave empty to disable auth)
API_KEY=

# Vector DB and documents dirs (set by docker-compose, override if needed)
# VECTOR_DB_DIR=/data
# DOCUMENTS_DIR=/data_and_documents
