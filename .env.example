APP_ENV=development
LOG_LEVEL=INFO
API_KEY=change-me
SHOW_SOURCES=1
WEB_BOOTSTRAP_ADMIN_TOKEN=change-me-bootstrap-token
PREPARE_RAG_ON_STARTUP=1
AUTO_INDEX_ON_STARTUP=1

OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL=mistral:7b
HF_EMBEDDING_MODEL=cointegrated/rubert-tiny2
CHROMA_COLLECTION_NAME=edu_documents
VECTOR_DB_DIR=./src/server/chrome_langchain_db
DOCUMENTS_DIR=./data_and_documents
RAG_TOP_K=4
RAG_HYBRID_DENSE_TOP_K=12
RAG_HYBRID_LEXICAL_TOP_K=12
RAG_HYBRID_RRF_K=60
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_LEXICAL_DB_PATH=./src/server/chrome_langchain_db/rag_lexical.db
RAG_TOTAL_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS=18
CONVERSATION_MEMORY_WINDOW=5
CONVERSATION_MEMORY_TTL_SECONDS=3600
CONVERSATION_MEMORY_MAX_SESSIONS=10000

API_BASE_URL=http://localhost:8000
BOT_TOKEN=replace-with-real-token

POSTGRES_DB=edu_assistant
POSTGRES_USER=edu_assistant
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://edu_assistant:change-me@db:5432/edu_assistant
